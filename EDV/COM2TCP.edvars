                        </VAR>
                        <!--.COM2TCP.edvAppli.User.Data.Source.DBType-->
                        <VAR ShortName="DBType" ClassName="VarSelection" AutoReset="0" Securized="0" ReadOnly="0" ValueType="String" SaveLocation=".">
                            <Value><![CDATA[XML]]></Value>
                        </VAR>
                        <!--.COM2TCP.edvAppli.User.Data.Source.DBUser-->
                        <VAR ShortName="DBUser" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="String" SaveLocation=".">
                            <Value><![CDATA[convergence]]></Value>
                        </VAR>
                        <DOM ShortName="DBType">
                            <!--.COM2TCP.edvAppli.User.Data.Source.DBType.InsertAuto-->
                            <VAR ShortName="InsertAuto" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="Boolean">
                                <Value><![CDATA[False]]></Value>
                            </VAR>
                            <!--.COM2TCP.edvAppli.User.Data.Source.DBType.InValues-->
                            <VAR ShortName="InValues" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="Boolean">
                                <Value><![CDATA[True]]></Value>
                            </VAR>
                            <!--.COM2TCP.edvAppli.User.Data.Source.DBType.Values-->
