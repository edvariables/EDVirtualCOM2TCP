                </VAR>
                <!--.COM2TCP.edvAppli.DataSource.DBPassword-->
                <VAR ShortName="DBPassword" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="Password" SaveLocation=".">
                    <Value Crypt="True"><![CDATA[rNr53jbT76+skz8oFAbAfg==]]></Value>
                </VAR>
                <!--.COM2TCP.edvAppli.DataSource.DBServer-->
                <VAR ShortName="DBServer" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="String" SaveLocation=".">
                    <Value><![CDATA[test]]></Value>
                </VAR>
                <!--.COM2TCP.edvAppli.DataSource.DBType-->
                <VAR ShortName="DBType" ClassName="VarSelection" AutoReset="0" Securized="0" ReadOnly="0" ValueType="Selection" SaveLocation=".">
                    <Value><![CDATA[Internal]]></Value>
                </VAR>
                <!--.COM2TCP.edvAppli.DataSource.DBUser-->
                <VAR ShortName="DBUser" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="String" SaveLocation=".">
