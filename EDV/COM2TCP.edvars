    <Version Major="1" Minor="472" Build="0" Revision="134">1.472.0.134</Version>
    <!--.COM2TCP-->
    <VAR ShortName="COM2TCP" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="Domain">
        <!--.COM2TCP.COMx-->
        <VAR ShortName="COMx" ClassName="Serial@EDVIO" AutoReset="0" Securized="0" ReadOnly="0" ValueType="Boolean" SaveLocation="V" Control="EDV.EDVIO.CtrlStream@EDVIO.DLL" />
        <!--.COM2TCP.edvAppli-->
        <VAR ShortName="edvAppli" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="Boolean" SaveLocation="V">
            <Meta><![CDATA[<DESIGNER.LASTPRESENTATION>Window</DESIGNER.LASTPRESENTATION>]]></Meta>
        </VAR>
        <!--.COM2TCP.TCP-->
        <VAR ShortName="TCP" ClassName="TCP@EDVIO" AutoReset="0" Securized="0" ReadOnly="0" ValueType="Boolean" SaveLocation="V" Control="EDV.EDVIO.CtrlStream@EDVIO.DLL" />
        <!--.COM2TCP.Visual-->
        <VAR ShortName="Visual" ClassName="VarVisual" AutoReset="0" Securized="0" ReadOnly="0" ValueType="Visual">
            <Meta><![CDATA[<DESIGNER.LASTPRESENTATION>Window</DESIGNER.LASTPRESENTATION>]]></Meta>
        </VAR>
        <DOM ShortName="COMx">
            <!--.COM2TCP.COMx.Number-->
            <VAR ShortName="Number" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="Byte" SaveLocation="U">
                <Value><![CDATA[6]]></Value>
            </VAR>
            <!--.COM2TCP.COMX.Received-->
            <VAR ShortName="Received" ClassName="" AutoReset="0" Securized="0" ReadOnly="1" ValueType="Text" />
            <!--.COM2TCP.COMX.Send-->
            <VAR ShortName="Send" ClassName="" AutoReset="1" Securized="0" ReadOnly="0" ValueType="Text" />
            <!--.COM2TCP.COMX.Settings-->
            <VAR ShortName="Settings" ClassName="SerialSettings@EDVIO" AutoReset="0" Securized="0" ReadOnly="1" ValueType="String">
                <Script><![CDATA["COM" + Number + ",9600,8,n,1"]]></Script>
            </VAR>
            <!--.COM2TCP.COMX.Status-->
            <VAR ShortName="Status" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="String" SaveLocation="V" />
        </DOM>
        <DOM ShortName="edvAppli">
            <!--.COM2TCP.edvAppli.ApplicationId-->
            <VAR ShortName="ApplicationId" ClassName="" AutoReset="0" Securized="1" ReadOnly="0" ValueType="String">
