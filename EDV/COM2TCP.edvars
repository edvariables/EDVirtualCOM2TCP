            <DOM ShortName="DataSource">
                <!--.COM2TCP.edvAppli.DataSource.DBName-->
                <VAR ShortName="DBName" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="String" SaveLocation=".">
