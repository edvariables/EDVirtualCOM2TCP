Console + File=
Console + Queue]]></Value>
                    </VAR>
                </DOM>
                <DOM ShortName="LogQueue">
                    <!--.COM2TCP.edvAppli.Log.LogQueue.Clear-->
                    <VAR ShortName="Clear" ClassName="" AutoReset="1" Securized="1" ReadOnly="0" ValueType="Boolean" />
                    <!--.COM2TCP.edvAppli.Log.LogQueue.Reduce-->
                    <VAR ShortName="Reduce" ClassName="EDVDelay@EDVFunctions" AutoReset="1" Securized="1" ReadOnly="1" ValueType="Boolean" />
                    <DOM ShortName="Clear">
                        <!--.COM2TCP.edvAppli.Log.LogQueue.Clear.OnChanging-->
                        <VAR ShortName="OnChanging" ClassName="" AutoReset="0" Securized="1" ReadOnly="1" ValueType="Null">
                            <Script><![CDATA[when(..:Changing)
{
	if(... != null)
		... = new Queue();
}
null;]]></Script>
                        </VAR>
                    </DOM>
                    <DOM ShortName="Reduce">
                        <!--.COM2TCP.edvAppli.Log.LogQueue.Reduce.OnChanging-->
                        <VAR ShortName="OnChanging" ClassName="" AutoReset="0" Securized="1" ReadOnly="1" ValueType="Null">
                            <Script><![CDATA[when(..:Changing)
{
	var logQueue;
	if ((logQueue = ...) != null) {
		var count : int = logQueue.Count;
		for(; count > 128; count--)
			logQueue.Dequeue();
	}
}
null;]]></Script>
                        </VAR>
                        <!--.COM2TCP.EDVAPPLI.LOG.LOGQUEUE.REDUCE.Period-->
                        <VAR ShortName="Period" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="Double">
                            <Value><![CDATA[86400000]]></Value>
                        </VAR>
                        <!--.COM2TCP.edvAppli.Log.LogQueue.Reduce.Repeat-->
                        <VAR ShortName="Repeat" ClassName="" AutoReset="0" Securized="1" ReadOnly="0" ValueType="Boolean">
                            <Value><![CDATA[True]]></Value>
                        </VAR>
                        <!--.COM2TCP.EDVAPPLI.LOG.LOGQUEUE.REDUCE.Start-->
                        <VAR ShortName="Start" ClassName="" AutoReset="1" Securized="0" ReadOnly="0" ValueType="Boolean" />
                        <DOM ShortName="Repeat">
                            <!--.COM2TCP.edvAppli.Log.LogQueue.Reduce.Repeat.OnChanging-->
                            <VAR ShortName="OnChanging" ClassName="" AutoReset="0" Securized="1" ReadOnly="1" ValueType="Null">
                                <Script><![CDATA[when(..)
{
	..Start;
}
null;]]></Script>
                            </VAR>
                        </DOM>
                    </DOM>
                </DOM>
            </DOM>
            <DOM ShortName="Midnight">
                <!--.COM2TCP.edvAppli.Midnight.LastTime-->
                <VAR ShortName="LastTime" ClassName="" AutoReset="0" Securized="1" ReadOnly="0" ValueType="DateTime" SaveLocation="V" />
                <!--.COM2TCP.edvAppli.Midnight.OnChanging-->
                <VAR ShortName="OnChanging" ClassName="" AutoReset="0" Securized="1" ReadOnly="1" ValueType="Null">
                    <Script><![CDATA[when(..:Changing){
	LastTime = DateTime.Now;
	try {
		//Action

		//Reset à 1H du mat
		Period = (24 - DateTime.Now.Hour + 1) * 3600 * 1000;
		Start;
	}
	catch(ex){
		edvError = :Name + " : " + ex;
		Period = 10000;
		Start;
	}
}
null;]]></Script>
                </VAR>
                <!--.COM2TCP.EDVAPPLI.MIDNIGHT.Period-->
                <VAR ShortName="Period" ClassName="" AutoReset="0" Securized="0" ReadOnly="0" ValueType="Double">
                    <Value><![CDATA[61200000]]></Value>
                </VAR>
                <!--.COM2TCP.EDVAPPLI.MIDNIGHT.Start-->
                <VAR ShortName="Start" ClassName="" AutoReset="1" Securized="0" ReadOnly="0" ValueType="Boolean" />
            </DOM>
